{
  "name": "zap-cli",
  "version": "0.1.0",
  "description": "Consent-safe consumer CLI for zap.co.il shopping research.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markes76/Zap-CLI.git"
  },
  "bugs": {
    "url": "https://github.com/markes76/Zap-CLI/issues"
  },
  "homepage": "https://github.com/markes76/Zap-CLI#readme",
  "keywords": [
    "zap",
    "shopping",
    "price-comparison",
    "cli",
    "agent",
    "israel"
  ],
  "bin": {
    "zap": "./dist/cli.js"
  },
  "files": [
    "assets",
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "fast-xml-parser": "^5.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
